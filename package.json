    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@league-of-foundry-developers/foundry-vtt-types": "^13.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
