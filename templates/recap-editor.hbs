<section class="eoh-recap-editor-form" style="display: flex; flex-direction: column; height: 100%;">
    <p style="margin-bottom: 8px; opacity: 0.7; font-size: 13px;">
        {{{localize "echoes-of-history.settings.recap-hint"}}}
    </p>
    <textarea
            name="recapText"
            style="flex: 1; width: 100%; min-height: 260px; font-family: monospace; font-size: 14px; resize: vertical;"
    >{{rawText}}</textarea>
    <footer class="sheet-footer flexrow" style="margin-top: 8px;">
        <button type="submit">
            <i class="fas fa-save"></i> Speichern
        </button>
    </footer>
</section>