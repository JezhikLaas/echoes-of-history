{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,

    "types": ["@league-of-foundry-developers/foundry-vtt-types"],

    "rootDir": "src",
    "noEmit": true
